# Bash Safety Checker Configuration
# Copy this file to .env and adjust values for your setup.

# LLM API base URL (OpenAI-compatible /v1/chat/completions) [REQUIRED]
BSC_API_URL=http://localhost:8080/v1

# Model name [REQUIRED]
BSC_MODEL=my-model-name

# Model profile: "general" (instruction-following LLM) or "safeguard" (gpt-oss-safeguard-20b)
# Controls prompt format, output parsing, and whether max_tokens is sent.
BSC_MODEL_PROFILE=general

# Request timeout in seconds
BSC_TIMEOUT=15

# Max tokens for LLM response. Increase for reasoning models. Ignored when BSC_MODEL_PROFILE=safeguard.
BSC_MAX_TOKENS=2048

# Shorten long strings (JWT, hashes, base64) in commands before sending to LLM (true/false)
BSC_SHORTEN_INPUT=false

# Extra fields to merge into the API request body (JSON string)
# Example: {"temperature": 0.1, "top_p": 0.9}
BSC_EXTRA_BODY={}

# Language for LLM descriptions (empty = English). Example: русский, deutsch, 日本語
BSC_LANGUAGE=

# Use Nerd Font icons where possible (true/false)
BSC_NERD_FONT_SUPPORT=false

# Log rotation: max size per file in KB, number of backup files to keep
# Total max disk usage = (BSC_LOG_MAX_KB) * (BSC_LOG_BACKUPS + 1)
# Default: 512 KB * 3 files = 1.5 MB max
BSC_LOG_MAX_KB=512
BSC_LOG_BACKUPS=2

# Auto-approve read-only commands without asking user (true/false)
BSC_AUTO_ALLOW_READONLY=false
